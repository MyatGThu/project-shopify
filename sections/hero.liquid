{%- comment -%}
  Hero with an optional background slideshow.
  - Add "Slide" blocks (image + focal point) for an auto-rotating, crossfading
    slideshow; or set a single background image. Falls back to a styled
    placeholder until either is set.
  - Focal point (object-position) keeps the subject framed across screen sizes
    (fixes awkward cropping on tablet/phone).
  - Text overlay animates in after the loader. Autoplay respects reduced-motion.
{%- endcomment -%}

{%- liquid
  assign slide_count = section.blocks.size
  assign has_bg = false
  if slide_count > 0 or section.settings.image != blank
    assign has_bg = true
  endif
-%}

<style>
  #hero-{{ section.id }} .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s var(--ease-in-out, ease);
  }
  #hero-{{ section.id }} .hero__slide.is-active { opacity: 1; }
  #hero-{{ section.id }} .hero__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--focal, center);
  }
</style>

<section
  id="hero-{{ section.id }}"
  class="hero{% unless has_bg %} hero--placeholder{% endunless %}"
  data-hero-intro
  {% if slide_count > 1 %}data-hero-slideshow data-autoplay="{{ section.settings.autoplay_speed | default: 5 }}"{% endif %}
>
  <div class="hero__media">
    {%- if slide_count > 0 -%}
      {%- for block in section.blocks -%}
        {%- liquid
          assign ld = 'lazy'
          if forloop.first
            assign ld = 'eager'
          endif
        -%}
        <div
          class="hero__slide{% if forloop.first %} is-active{% endif %}"
          style="--focal: {{ block.settings.focal | default: 'center' }};"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 2400
              | image_tag:
                loading: ld,
                sizes: '100vw',
                widths: '600, 900, 1200, 1600, 2000, 2400',
                alt: block.settings.image.alt | default: section.settings.heading
            }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- elsif section.settings.image != blank -%}
      <div class="hero__slide is-active" style="--focal: {{ section.settings.focal | default: 'center' }};">
        {{
          section.settings.image
          | image_url: width: 2400
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            widths: '600, 900, 1200, 1600, 2000, 2400',
            alt: section.settings.image.alt | default: section.settings.heading
        }}
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.side_label != blank -%}
    <span class="hero__sidelabel">{{ section.settings.side_label }}</span>
  {%- endif -%}

  <div class="container">
    <div class="hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow" style="color: rgba(242, 242, 240, 0.8);">
          <span data-hero-stagger style="display: inline-block;">{{ section.settings.eyebrow }}</span>
        </p>
      {%- endif -%}

      <h1 class="hero__title">
        {%- assign lines = section.settings.heading | newline_to_br | split: '<br />' -%}
        {%- for line in lines -%}
          <span style="display: block; overflow: hidden;">
            <span data-hero-stagger style="display: block;">
              {%- if section.settings.accent_last_line and forloop.last and lines.size > 1 -%}
                <em>{{ line | strip }}</em>
              {%- else -%}
                {{ line | strip }}
              {%- endif -%}
            </span>
          </span>
        {%- endfor -%}
      </h1>

      {%- if section.settings.text != blank -%}
        <p class="lead" style="color: rgba(242, 242, 240, 0.85); margin-top: var(--space-md); max-width: 36ch;">
          <span data-hero-stagger style="display: inline-block;">{{ section.settings.text }}</span>
        </p>
      {%- endif -%}

      <div class="hero__cta" data-hero-stagger>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--accent">
            {{- section.settings.button_label -}}
          </a>
        {%- endif -%}
        {%- if section.settings.button2_label != blank -%}
          <a href="{{ section.settings.button2_link }}" class="btn btn--ghost" style="color: var(--color-on-ink);">
            {{- section.settings.button2_label -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if section.settings.scroll_cue != blank -%}
    <span class="hero__scrollcue">{{ section.settings.scroll_cue }}</span>
  {%- endif -%}

  {%- if slide_count > 1 -%}
    <script>
      (function () {
        var hero = document.currentScript.closest(".hero");
        if (!hero) return;
        var slides = hero.querySelectorAll(".hero__slide");
        if (slides.length < 2) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var i = 0;
        var delay = (parseFloat(hero.getAttribute("data-autoplay")) || 5) * 1000;
        setInterval(function () {
          slides[i].classList.remove("is-active");
          i = (i + 1) % slides.length;
          slides[i].classList.add("is-active");
        }, delay);
      })();
    </script>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "header", "content": "Background" },
    {
      "type": "paragraph",
      "content": "Add Slide blocks for an auto-rotating slideshow, or set one image below. Use the focal point to keep the subject framed on phones."
    },
    { "type": "image_picker", "id": "image", "label": "Single background image", "info": "Used only when no slides are added." },
    {
      "type": "select",
      "id": "focal",
      "label": "Single image focal point",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Slideshow speed",
      "default": 5
    },
    { "type": "header", "content": "Text" },
    { "type": "text", "id": "side_label", "label": "Vertical side label", "default": "melbourne · est. 2026" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "spring campaign" },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "Each line animates separately; the last line is the italic accent.",
      "default": "i make\nnice things"
    },
    { "type": "checkbox", "id": "accent_last_line", "label": "Italicise the last line", "default": true },
    { "type": "text", "id": "text", "label": "Subtext", "default": "made-to-order pieces, modeled by me. (yes, i'm AI.)" },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "shop the drop" },
    { "type": "url", "id": "button_link", "label": "Primary link" },
    { "type": "text", "id": "button2_label", "label": "Secondary button", "default": "meet melina" },
    { "type": "url", "id": "button2_link", "label": "Secondary link" },
    { "type": "text", "id": "scroll_cue", "label": "Scroll cue", "default": "scroll" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select",
          "id": "focal",
          "label": "Focal point",
          "info": "Keeps the subject in frame on small screens.",
          "options": [
            { "value": "center", "label": "Center" },
            { "value": "top", "label": "Top" },
            { "value": "bottom", "label": "Bottom" },
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "right"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
