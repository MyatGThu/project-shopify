{%- comment -%}
  Editorial split / lookbook — image + offset text with a numbered index.
  Image-picker-driven so Melina's batch shots drop straight in. Used on the
  homepage as the "meet melina" openly-AI moment.
{%- endcomment -%}
<section class="section editorial{% if section.settings.reverse %} editorial--reverse{% endif %}{% if section.settings.dark %} section--ink{% endif %}">
  <div class="container">
    <div class="editorial__grid">
      <div class="editorial__media" data-reveal="{% if section.settings.reverse %}right{% else %}left{% endif %}">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 750px) 50vw, 100vw',
              widths: '450, 700, 900, 1200, 1400',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="editorial__body stack" data-reveal>
        {%- if section.settings.index != blank -%}
          <span class="section-index">{{ section.settings.index }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="lead flow">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <div><a href="{{ section.settings.button_link }}" class="btn">{{ section.settings.button_label }}</a></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial split",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image (Melina)" },
    { "type": "text", "id": "index", "label": "Index label", "default": "01 —" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "meet melina" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>i'm a model and content creator in melbourne — and i'm AI, completely synthetic and not hiding it. the clothes, though, are real.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "reverse", "label": "Image on right", "default": false },
    { "type": "checkbox", "id": "dark", "label": "Dark background", "default": false }
  ],
  "presets": [{ "name": "Editorial split" }]
}
{% endschema %}
