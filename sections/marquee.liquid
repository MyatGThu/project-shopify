{%- comment -%}
  Moving marquee of brand statements. Decorative (aria-hidden); CSS in base.css.
  Blocks are duplicated once so the loop is seamless at translateX(-50%).
{%- endcomment -%}
<section class="marquee{% if section.settings.dark %} marquee--dark{% endif %}" aria-hidden="true">
  <div class="marquee__track" style="--marquee-duration: {{ section.settings.speed | default: 28 }}s;">
    {%- for n in (1..2) -%}
      {%- for block in section.blocks -%}
        <span class="marquee__item" {{ block.shopify_attributes }}>
          {{- block.settings.text -}}
          <span class="marquee__sep">{{ section.settings.separator | default: '✳' }}</span>
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "range", "id": "speed", "min": 10, "max": 60, "step": 2, "unit": "s", "label": "Scroll duration", "default": 28 },
    { "type": "text", "id": "separator", "label": "Separator", "default": "✳" },
    { "type": "checkbox", "id": "dark", "label": "Dark background", "default": true }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Phrase",
      "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "made to order" }]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "made to order" } },
        { "type": "item", "settings": { "text": "modeled by melina" } },
        { "type": "item", "settings": { "text": "zero waste" } },
        { "type": "item", "settings": { "text": "openly AI" } },
        { "type": "item", "settings": { "text": "shipped worldwide" } }
      ]
    }
  ]
}
{% endschema %}
