[
  {
    "name": "theme_info",
    "theme_name": "Melina — POD (Relatable-Glam)",
    "theme_version": "0.2.0",
    "theme_author": "Project — Shopify",
    "theme_documentation_url": "https://github.com/MyatGThu/Project---Shopify",
    "theme_support_url": "https://github.com/MyatGThu/Project---Shopify/issues"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Relatable-glam direction (per the character bible). Friendlier serif + clean sans, lowercase casual voice. See docs/DESIGN_SYSTEM.md."
      },
      {
        "type": "paragraph",
        "content": "Tip: if your store's font library includes them, Instrument Serif or Fraunces (heading) read even more contemporary."
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "lora_n5"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "inter_n4"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg", "label": "Background (cool paper)", "default": "#f2f2f0" },
      { "type": "color", "id": "color_surface", "label": "Surface / cards", "default": "#ffffff" },
      { "type": "color", "id": "color_ink", "label": "Text (jet-black)", "default": "#141414" },
      { "type": "color", "id": "color_muted", "label": "Muted text", "default": "#6b6e6b" },
      { "type": "color", "id": "color_line", "label": "Hairline borders", "default": "#e3e3df" },
      { "type": "color", "id": "color_accent", "label": "Accent — grey-green (her eyes)", "default": "#6e7d71" },
      { "type": "color", "id": "color_gold", "label": "Gold (her jewellery — use sparingly)", "default": "#c2a35a" },
      { "type": "color", "id": "color_ink_bg", "label": "Dark sections background", "default": "#141414" },
      { "type": "color", "id": "color_on_ink", "label": "Text on dark sections", "default": "#f2f2f0" }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1100,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1400
      }
    ]
  },
  {
    "name": "Loading screen",
    "settings": [
      { "type": "checkbox", "id": "loading_enabled", "label": "Enable loading screen", "default": true },
      {
        "type": "text",
        "id": "loading_text",
        "label": "Loader mark",
        "info": "Shown on the loading screen. Defaults to the store name.",
        "default": "melina"
      }
    ]
  },
  {
    "name": "Branding",
    "settings": [{ "type": "image_picker", "id": "favicon", "label": "Favicon" }]
  }
]
